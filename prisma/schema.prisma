// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String             @id @default(cuid())
  name         String?
  interests    String             @default("[]") // JSON array of interest strings
  preferences  String             @default("{}") // JSON: { minBlock, maxBlock }
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  activities   ActivityInstance[]
}

model ActivityTemplate {
  id              String    @id @default(cuid())
  name            String
  description     String
  minDuration     Int                // minutes
  maxDuration     Int                // minutes
  requiredContext String    @default("{}") // JSON: { minTimeAvailable, preferredTimes, locations }
  generatorType   String    @default("static") // "static" | "llm"
  contentSource   String?            // e.g. "youtube_playlist", "article_feed", "reflection"
  interestTags    String    @default("[]") // JSON array – which interests this template fits
  contextTags     String    @default("[]") // JSON array – "morning","evening","commute","home","focus"
  createdAt       DateTime  @default(now())
}

model ActivityInstance {
  id             String    @id @default(cuid())
  userId         String
  templateId     String
  title          String
  description    String
  estimatedTime  Int               // minutes
  resourceUrl    String?
  status         String    @default("pending") // "pending"|"completed"|"skipped"|"later"|"stale"
  skippedReason  String?
  suggestedAt    DateTime  @default(now())
  completedAt    DateTime?
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id])
}
